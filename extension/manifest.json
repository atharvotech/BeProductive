{
  "manifest_version": 3,
  "name": "Focus Engine Pro",
  "version": "1.0.0",
  "description": "Track browsing time, block distractions, and stay focused. Works with Focus Engine Pro desktop app.",
  "permissions": [
    "tabs",
    "activeTab",
    "webNavigation",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}
